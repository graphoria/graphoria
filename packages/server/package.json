{
  "name": "@graphoria/server",
  "version": "0.1.2",
  "description": "Auto-generated GraphQL and REST APIs from database schema - Connect your database to modern APIs instantly",
  "keywords": [
    "auto-generated",
    "bun",
    "data-api",
    "database",
    "graphoria",
    "graphql",
    "hasura-alternative",
    "mssql",
    "mysql",
    "postgresql",
    "rest-api",
    "schema",
    "typescript"
  ],
  "homepage": "https://github.com/graphoria/graphoria#readme",
  "bugs": {
    "url": "https://github.com/graphoria/graphoria/issues"
  },
  "license": "Apache-2.0",
  "author": "Alex Ferreli <ferreli.ale@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphoria/graphoria.git",
    "directory": "packages/server"
  },
  "bin": {
    "graphoria": "./cli.ts"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__test/**",
    "playgrounds/**/*.html",
    "dist",
    "!dist/src/__test/**",
    "cli.ts",
    "standalone.ts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./config": {
      "types": "./dist/src/config/index.d.ts",
      "bun": "./src/config/index.ts",
      "import": "./src/config/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "cluster": "bun run cli.ts --cluster",
    "start": "bun run src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "standalone": "bun run cli.ts",
    "auth:seed": "bun run cli.ts seed-auth",
    "build:playgrounds": "bun run scripts/build-playgrounds.ts",
    "prebuild": "bun run build:playgrounds",
    "predev": "bun run prebuild",
    "prestart": "bun run prebuild",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "amqplib": "0.10.9",
    "croner": "9.1.0",
    "es-toolkit": "1.44.0",
    "graphql": "^16.13.1",
    "jose": "6.1.3",
    "kafkajs": "2.2.4",
    "lru-cache": "11.2.4",
    "mssql": "12.2.0",
    "nanoid": "5.1.6",
    "openapi-types": "12.1.3",
    "oxfmt": "^0.51.0",
    "paseto-ts": "^2.0.5",
    "path-to-regexp": "8.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.2",
    "sql-formatter": "15.7.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.8",
    "@types/kafkajs": "1.9.0",
    "@types/mssql": "9.1.9"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "openai": "^4.77.3"
  },
  "engines": {
    "bun": ">=1.3.4"
  }
}
