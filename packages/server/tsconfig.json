{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["bun", "react"],
    "composite": true,
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false
  },
  "include": ["src/**/*", "standalone.ts", "cli.ts", "package.json"],
  "exclude": ["node_modules", "dist"]
}
