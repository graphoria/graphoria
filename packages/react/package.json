{
  "name": "@graphoria/react",
  "version": "0.1.0",
  "description": "React hooks and utilities for Graphoria GraphQL APIs (client-agnostic)",
  "keywords": [
    "authentication",
    "graphoria",
    "graphql",
    "hooks",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/graphoria/graphoria#readme",
  "bugs": {
    "url": "https://github.com/graphoria/graphoria/issues"
  },
  "license": "Apache-2.0",
  "author": "Alex Ferreli <ferreli.ale@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphoria/graphoria.git",
    "directory": "packages/react"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/__test/**",
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@sinonjs/fake-timers": "^15.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "happy-dom": "^20.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "typescript": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
