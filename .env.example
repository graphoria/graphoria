# ─── Core ──────────────────────────────────────────────────────────────
# HTTP port the server listens on.
PORT=3000
# DEVELOPMENT | PRODUCTION — affects logging and error verbosity.
NODE_ENV=DEVELOPMENT
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug
# REQUIRED. Master secret; sending it in the admin header bypasses RBAC.
# Has no default — the server will NOT boot without it.
ADMIN_SECRET=change-me
# Path to your configuration file. Overrides the `configuration` option passed in code.
# CONFIGURATION=./graphoria.ts
# Global path prefix applied to every route (e.g. "/api").
PREFIX=
# Enable CORS.
CORS_ENABLED=true

# ─── Authentication ────────────────────────────────────────────────────
# Token strategy: jwt (default) | paseto_local | paseto_public.
# AUTH_STRATEGY=jwt
# Role assigned to unauthenticated requests.
ANONYMOUS_ROLE=anonymous
# REQUIRED for the default "jwt" strategy. HMAC secret used to sign tokens.
JWT_SECRET=
# Access-token lifetime (e.g. 5m, 1h).
JWT_EXPIRES_IN=5m
# Refresh-token lifetime.
JWT_RT_EXPIRES_IN=7d
# PASETO keys — only needed when AUTH_STRATEGY is paseto_local / paseto_public.
PASETO_LOCAL_KEY=
PASETO_SECRET_KEY=
PASETO_PUBLIC_KEY=

# ─── Cache & Redis ─────────────────────────────────────────────────────
# memory (default) | redis. Redis is required when auth is enabled
# (it backs the token revocation/replay store).
CACHE_STORE=memory
# Redis/Valkey connection URL.
REDIS_URL=redis://localhost:6379

# ─── Endpoints & headers ───────────────────────────────────────────────
REST_API_PREFIX=/rest
GRAPHQL_API_ENDPOINT=/graphql
GRAPHIQL_ENDPOINT=/graphiql
SCALAR_ENDPOINT=/scalar
OPENAPI_ENDPOINT=/openapi.json
# Header carrying the admin secret.
ADMIN_SECRET_HEADER=x-admin-secret
# Header carrying the bearer token.
AUTHORIZATION_HEADER=authorization

# ─── Superadmin & console ──────────────────────────────────────────────
SUPERADMIN_ROLE=superadmin
# Expose the admin console UI + status APIs (admin-secret gated).
CONSOLE_ENABLED=false
CONSOLE_ENDPOINT=/_console

# ─── Schema output & debugging ─────────────────────────────────────────
# Write the generated per-role GraphQL schemas to disk.
PRINT_SCHEMAS=false
SCHEMAS_OUTPUT_DIR=./.graphoria/schemas
# Re-query the row after a mutation so the response reflects fresh data.
QUERY_ON_RESPONSE=false
# Reject GraphQL queries deeper than this (0 = unlimited).
MAX_QUERY_DEPTH=0

# ─── AI agent & MCP (optional) ─────────────────────────────────────────
# Enable the /ai natural-language endpoint (admin-secret only).
# AI_ENABLED=false
AI_GRAPHQL_ENABLED=true
AI_REST_ENABLED=true
# Enable the /mcp Model Context Protocol endpoint (anonymous-only by default).
# AI_MCP_ENABLED=false
AI_MCP_ENDPOINT=/mcp
AI_MCP_REQUIRE_ADMIN_SECRET=false
# AI_MCP_MAX_QUERY_DEPTH=
# Comma-separated names to disable.
AI_MCP_DISABLED_TOOLS=
AI_MCP_DISABLED_RESOURCES=
AI_MCP_DISABLED_PROMPTS=
# Override the AI agent system prompt / template.
# AI_SYSTEM_PROMPT=
# AI_PROMPT_TEMPLATE=
