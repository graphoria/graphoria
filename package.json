{
  "name": "@graphoria/monorepo",
  "version": "0.1.0",
  "description": "Graphoria monorepo - Auto-generated GraphQL and REST APIs from database schema",
  "homepage": "https://github.com/graphoria/graphoria#readme",
  "bugs": {
    "url": "https://github.com/graphoria/graphoria/issues"
  },
  "license": "Apache-2.0",
  "author": "Alex Ferreli <ferreli.ale@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphoria/graphoria.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @graphoria/server dev",
    "dev:server": "bun run --filter @graphoria/server dev",
    "build": "bun run --filter '!@graphoria/playgrounds' build",
    "build:server": "bun run --filter @graphoria/server build",
    "build:react": "bun run --filter @graphoria/react build",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "type-check": "bun run --filter '!@graphoria/playgrounds' type-check",
    "test": "bun test",
    "test:server": "bun test packages/server",
    "test:react": "bun test packages/react"
  },
  "devDependencies": {
    "@types/bun": "1.3.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.51.0",
    "oxlint": "1.40.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.4"
  }
}
